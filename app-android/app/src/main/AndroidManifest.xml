<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.ConectaTarot"
        android:usesCleartextTraffic="true">
        <activity
            android:name=".SplashActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.ConectaTarot">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity android:name=".MainActivity" />
        <activity android:name=".ClienteActivity" />
        <activity android:name=".TarotistaDetalleActivity" />
        <activity android:name=".AgendarActivity" />
        <activity android:name=".MisSesionesActivity" />
        <activity android:name=".HistorialSesionesActivity" />
        <activity android:name=".HistorialPagosActivity" />
        <activity android:name=".TarotistaHomeActivity" />
        <activity android:name=".RegistroActivity" />
        <activity android:name=".RegistroTarotistaActivity" />
        <activity android:name=".PerfilActivity" />
        <activity android:name=".PerfilTarotistaActivity" />
        <activity android:name=".HistorialTarotistaActivity" />
        <activity android:name=".PagosTarotistaActivity" />
        <activity android:name=".SeleccionRolActivity" />
        <activity android:name=".CompletarPerfilTarotistaActivity" />
        <activity
            android:name=".AdminActivity"
            android:exported="false"
            android:label="@string/title_activity_admin"
            android:theme="@style/Theme.ConectaTarot"
            android:windowSoftInputMode="adjustResize" />
        <activity
            android:name=".GestionUsuariosActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />
        <activity
            android:name=".GestionTarotistasActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />
        <activity
            android:name=".GestionPagosActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />
        <activity
            android:name=".GestionEspecialidadesActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />
    </application>

</manifest>