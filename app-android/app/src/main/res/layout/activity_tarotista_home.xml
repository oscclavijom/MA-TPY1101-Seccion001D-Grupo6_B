<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#1a0a2e"
    android:paddingTop="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tvBienvenidoTarotista"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#d4aaff"
            android:textSize="18sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/tvCerrarSesionTarotista"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Salir"
            android:textColor="#e74c3c"
            android:textSize="14sp"/>

    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="📅 Mi Agenda"
        android:textColor="#e8c3ff"
        android:textSize="16sp"
        android:textStyle="bold"
        android:paddingLeft="16dp"
        android:paddingBottom="8dp"/>

    <TextView
        android:id="@+id/tvEmptyAgenda"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="No tienes sesiones pendientes"
        android:textColor="#9b59b6"
        android:textSize="16sp"
        android:layout_gravity="center"
        android:layout_marginTop="60dp"
        android:visibility="gone"/>

    <Button
        android:id="@+id/btnEditarPerfilTarotista"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="✏️ Editar mi perfil"
        android:textColor="#ffffff"
        android:backgroundTint="#2d1654"
        android:textSize="14sp"
        android:layout_marginLeft="16dp"
        android:layout_marginRight="16dp"
        android:layout_marginBottom="8dp"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvAgenda"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="8dp"/>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#2d1654"
        app:itemIconTint="#d4aaff"
        app:itemTextColor="#d4aaff"
        app:menu="@menu/tarotista_bottom_nav_menu"
        xmlns:app="http://schemas.android.com/apk/res-auto"/>

</LinearLayout>