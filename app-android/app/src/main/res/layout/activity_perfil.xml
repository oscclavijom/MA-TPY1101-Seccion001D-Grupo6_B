<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#1a0a2e">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:id="@+id/tvVolverPerfil"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="← Volver"
                android:textColor="#9b59b6"
                android:textSize="14sp"
                android:layout_marginBottom="24dp"/>

            <TextView
                android:text="👤"
                android:textSize="64sp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:text="Mi Perfil"
                android:textColor="#d4aaff"
                android:textSize="26sp"
                android:textStyle="bold"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginBottom="32dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nombre"
                android:textColor="#e8c3ff"
                android:textSize="14sp"
                android:layout_marginBottom="8dp"/>

            <EditText
                android:id="@+id/etPerfilNombre"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:textColor="#ffffff"
                android:textColorHint="#9b59b6"
                android:background="#2d1654"
                android:padding="16dp"
                android:inputType="textPersonName"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Email"
                android:textColor="#e8c3ff"
                android:textSize="14sp"
                android:layout_marginBottom="8dp"/>

            <EditText
                android:id="@+id/etPerfilEmail"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:textColor="#ffffff"
                android:textColorHint="#9b59b6"
                android:background="#2d1654"
                android:padding="16dp"
                android:inputType="textEmailAddress"
                android:layout_marginBottom="32dp"/>

            <Button
                android:id="@+id/btnGuardarPerfil"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Guardar cambios"
                android:textColor="#ffffff"
                android:backgroundTint="#7d3cae"
                android:textSize="16sp"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:id="@+id/tvResultadoPerfil"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="14sp"
                android:layout_gravity="center"
                android:gravity="center"/>

        </LinearLayout>

    </ScrollView>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#2d1654"
        app:itemIconTint="#d4aaff"
        app:itemTextColor="#d4aaff"
        app:menu="@menu/bottom_nav_menu"
        xmlns:app="http://schemas.android.com/apk/res-auto"/>

</LinearLayout>