<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#1a0a2e">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:id="@+id/tvVolverPerfilTarotista"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="← Volver"
                android:textColor="#9b59b6"
                android:textSize="14sp"
                android:layout_marginBottom="24dp"/>

            <TextView
                android:text="🔮"
                android:textSize="64sp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:text="Mi Perfil Profesional"
                android:textColor="#d4aaff"
                android:textSize="24sp"
                android:textStyle="bold"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:text="Esta información verán los clientes"
                android:textColor="#9b59b6"
                android:textSize="13sp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginBottom="32dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nombre profesional"
                android:textColor="#e8c3ff"
                android:textSize="14sp"
                android:layout_marginBottom="8dp"/>

            <EditText
                android:id="@+id/etEditNombrePro"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:hint="Ej: Luna Estrellada"
                android:textColor="#ffffff"
                android:textColorHint="#9b59b6"
                android:background="#2d1654"
                android:padding="16dp"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Descripción"
                android:textColor="#e8c3ff"
                android:textSize="14sp"
                android:layout_marginBottom="8dp"/>

            <EditText
                android:id="@+id/etEditDescripcion"
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:hint="Cuéntales tu experiencia..."
                android:textColor="#ffffff"
                android:textColorHint="#9b59b6"
                android:background="#2d1654"
                android:padding="16dp"
                android:gravity="top"
                android:inputType="textMultiLine"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Precio por hora (CLP)"
                android:textColor="#e8c3ff"
                android:textSize="14sp"
                android:layout_marginBottom="8dp"/>

            <EditText
                android:id="@+id/etEditPrecio"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:hint="Ej: 15000"
                android:textColor="#ffffff"
                android:textColorHint="#9b59b6"
                android:background="#2d1654"
                android:padding="16dp"
                android:inputType="number"
                android:layout_marginBottom="24dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Especialidades"
                android:textColor="#e8c3ff"
                android:textSize="14sp"
                android:layout_marginBottom="8dp"/>

            <LinearLayout
                android:id="@+id/llEspecialidadesPerfil"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="24dp"/>

            <TextView
                android:id="@+id/tvCargandoEspecialidadesPerfil"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cargando especialidades..."
                android:textColor="#9b59b6"
                android:textSize="13sp"
                android:layout_marginBottom="24dp"
                android:visibility="gone"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Disponibilidad"
                android:textColor="#e8c3ff"
                android:textSize="14sp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp"/>

            <CheckBox
                android:id="@+id/cbLunesPerfil"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Lunes"
                android:textColor="#ffffff"/>

            <CheckBox
                android:id="@+id/cbMartesPerfil"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Martes"
                android:textColor="#ffffff"/>

            <CheckBox
                android:id="@+id/cbMiercolesPerfil"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Miércoles"
                android:textColor="#ffffff"/>

            <CheckBox
                android:id="@+id/cbJuevesPerfil"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Jueves"
                android:textColor="#ffffff"/>

            <CheckBox
                android:id="@+id/cbViernesPerfil"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Viernes"
                android:textColor="#ffffff"/>

            <CheckBox
                android:id="@+id/cbSabadoPerfil"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sábado"
                android:textColor="#ffffff"/>

            <CheckBox
                android:id="@+id/cbDomingoPerfil"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Domingo"
                android:textColor="#ffffff"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hora inicio"
                android:textColor="#e8c3ff"
                android:layout_marginTop="12dp"/>

            <EditText
                android:id="@+id/etHoraInicioPerfil"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:hint="09:00"
                android:focusable="false"
                android:clickable="true"
                android:textColor="#ffffff"
                android:textColorHint="#9b59b6"
                android:background="#2d1654"
                android:padding="16dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hora fin"
                android:textColor="#e8c3ff"
                android:layout_marginTop="12dp"/>

            <EditText
                android:id="@+id/etHoraFinPerfil"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:hint="18:00"
                android:focusable="false"
                android:clickable="true"
                android:textColor="#ffffff"
                android:textColorHint="#9b59b6"
                android:background="#2d1654"
                android:padding="16dp"
                android:layout_marginBottom="32dp"/>

            <Button
                android:id="@+id/btnGuardarPerfilTarotista"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Guardar cambios"
                android:textColor="#ffffff"
                android:backgroundTint="#7d3cae"
                android:textSize="16sp"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:id="@+id/tvResultadoPerfilTarotista"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="14sp"
                android:layout_gravity="center"
                android:gravity="center"/>

        </LinearLayout>

    </ScrollView>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#2d1654"
        app:itemIconTint="#d4aaff"
        app:itemTextColor="#d4aaff"
        app:menu="@menu/tarotista_bottom_nav_menu"
        xmlns:app="http://schemas.android.com/apk/res-auto"/>

</LinearLayout>